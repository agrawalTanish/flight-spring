#!/bin/sh
DIR=$(dirname "$0")
MAVEN_HOME="$DIR/.mvn/apache-maven-3.9.6"
MAVEN_ZIP="$DIR/.mvn/maven.zip"
if [ ! -d "$MAVEN_HOME" ]; then
    mkdir -p "$DIR/.mvn"
    if command -v curl >/dev/null 2>&1; then
        curl -sL "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip" -o "$MAVEN_ZIP"
    elif command -v wget >/dev/null 2>&1; then
        wget -q "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip" -O "$MAVEN_ZIP"
    else
        exit 1
    fi
    unzip -q "$MAVEN_ZIP" -d "$DIR/.mvn"
    rm "$MAVEN_ZIP"
fi
chmod +x "$MAVEN_HOME/bin/mvn"
"$MAVEN_HOME/bin/mvn" "$@"
